  "dialogueNodes": [
    {
      "id": "clara_intro_start",
      "characterId": "clara_vale",
      "characterImage": "/cases/the-day-we-would-meet/character/clara_neutral.png",
      "lines": [
        { "speakerId": "clara_vale", "text": "Oh - I didn't hear you come in. Not many people wander into the library this early." },
        { "speakerId": "clara_vale", "text": "I'm Clara. Clara Vale." }
      ],
      "choices": [
        {
          "id": "clara_befriend",
          "text": "It's nice to meet you, Clara. Mind if I stay a while?",
          "effects": [
            { "type": "changeRelationship", "characterId": "clara_vale", "metric": "trust", "amount": 5 },
            { "type": "changeRelationship", "characterId": "clara_vale", "metric": "affection", "amount": 10 }
          ],
          "nextDialogueId": "clara_after_befriend"
        },
        {
          "id": "clara_distant",
          "text": "Just passing through.",
          "effects": [{ "type": "changeRelationship", "characterId": "clara_vale", "metric": "affection", "amount": -5 }],
          "nextDialogueId": "clara_after_distant"
        }
      ]
    },
    {
      "id": "clara_after_befriend",
      "characterId": "clara_vale",
      "characterImage": "/cases/the-day-we-would-meet/character/clara_happy.png",
      "lines": [
        { "speakerId": "clara_vale", "text": "Well, in that case - stay as long as you like. I don't mind the company." }
      ],
      "choices": [{ "id": "clara_after_befriend_end", "text": "I'll see you around, Clara.", "nextDialogueId": null }]
    },
    {
      "id": "clara_after_distant",
      "characterId": "clara_vale",
      "characterImage": "/cases/the-day-we-would-meet/character/clara_confused.png",
      "lines": [{ "speakerId": "clara_vale", "text": "...Suit yourself, then." }],
      "choices": [{ "id": "clara_after_distant_end", "text": "...", "nextDialogueId": null }]
